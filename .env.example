# SQLite (default — single user, no extra setup)
DATABASE_URL=sqlite:///data/birdie_book.db

# PostgreSQL (uncomment for multi-user deployment)
# DATABASE_URL=postgresql://birdie:birdie@localhost:5432/birdie_book
GOOGLE_MAPS_API_KEY=your_key_here
HOST=0.0.0.0
PORT=8000
IMAGE_STORAGE_PATH=./app/static/images/holes

# CORS — set to Vite dev server URL for local development
# CORS_ORIGINS=http://localhost:5173
